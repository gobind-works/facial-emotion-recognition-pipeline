        "                 cmap=\"Blues\",  # Change to blue\n",
        "                 yticklabels=labels, xticklabels=labels,\n",
        "                 vmin=0, vmax=np.max(cm_normalised),\n",
        "                 fmt=\".2f\", annot_kws={\"size\": 20})\n",
        "\n",
        "# Set axis labels\n",
